# Iris AI Gateway 环境配置
# 复制此文件为 .env 并填入实际值

# === 服务配置 ===
IRIS_HOST=0.0.0.0
IRIS_PORT=8000
IRIS_DEBUG=true
IRIS_LOG_LEVEL=info

# === API 密钥 (上游 Provider) ===
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# === 上游 Provider 配置 ===
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_ORGANIZATION=org-your-org-id
UPSTREAM_TIMEOUT=120
UPSTREAM_MAX_RETRIES=3

# === 网关认证 ===
# 多个 API Key 用逗号分隔
IRIS_API_KEYS=iris-key-1,iris-key-2

# === 记忆系统 ===
MEMORY_BACKEND=sqlite
MEMORY_DB_PATH=./data/memory/iris.db
MEMORY_MAX_SHORT_TERM=20
MEMORY_SUMMARY_THRESHOLD=10

# === Redis (可选，用于分布式记忆) ===
# REDIS_URL=redis://localhost:6379/0

# === 感知系统 ===
PERCEPTION_ENABLED=true

# === 人格配置 ===
PERSONA_CONFIG_DIR=./config/personas

# === Claude Code 伪装 (用于绕过 Anthropic 调用源限制) ===
# 启用后，调用 Anthropic API 时会模拟 Claude Code 的请求特征
CLAUDE_DISGUISE_ENABLED=false
CLAUDE_DISGUISE_USER_AGENT=ClaudeCode/0.2.32 (darwin; arm64)
# 额外 Headers 为 JSON 格式
# CLAUDE_DISGUISE_EXTRA_HEADERS={"X-Stainless-Arch":"arm64"}

# === OpenAI 伪装 ===
OPENAI_DISGUISE_ENABLED=false
