# Iris AI Gateway 环境配置
# 复制此文件为 .env 并填入实际值

# === 服务配置 ===
IRIS_HOST=0.0.0.0
IRIS_PORT=8000
IRIS_DEBUG=true
IRIS_LOG_LEVEL=info
IRIS_ENVIRONMENT=development
CORS_ORIGINS=*

# === API 密钥 (上游 Provider) ===
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# === 上游 Provider 配置 ===
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_ORGANIZATION=org-your-org-id
UPSTREAM_TIMEOUT=120
UPSTREAM_MAX_RETRIES=3

# === 网关认证 ===
# 多个 API Key 用逗号分隔
IRIS_API_KEYS=iris-key-1,iris-key-2

# === 记忆系统 ===
MEMORY_BACKEND=sqlite
MEMORY_DB_PATH=./data/memory/iris.db
MEMORY_MAX_SHORT_TERM=20
MEMORY_SUMMARY_THRESHOLD=10

# === Ombre-Brain 远程 MCP 连接 ===
# 使用本地 Ombre-Brain 时不需要配置；使用远程 MCP 服务时填写
# OMBRE_MCP_URL=http://192.168.31.120:18001/mcp
# OMBRE_MCP_TOKEN=Bearer sk-your-ombre-mcp-token

# === Redis (可选，用于分布式记忆) ===
# REDIS_URL=redis://localhost:6379/0

# === 感知系统 ===
PERCEPTION_ENABLED=true

# === 人格配置 ===
PERSONA_CONFIG_DIR=./config/personas

# === Claude Code 伪装 (用于绕过 Anthropic 调用源限制) ===
# 启用后，调用 Anthropic API 时会模拟 Claude Code 的请求特征
CLAUDE_DISGUISE_ENABLED=false
CLAUDE_DISGUISE_USER_AGENT=ClaudeCode/0.2.32 (darwin; arm64)
# 额外 Headers 为 JSON 格式
# CLAUDE_DISGUISE_EXTRA_HEADERS={"X-Stainless-Arch":"arm64"}

# === OpenAI 伪装 ===
OPENAI_DISGUISE_ENABLED=false

# === 模型配置 ===
# JSON 格式；留空时使用内置默认模型列表与别名
# MODEL_ALIASES={"sonnet":"claude-sonnet-4-20250514"}
# MODEL_PROVIDERS={"claude-sonnet-4-20250514":"anthropic","gpt-4o":"openai"}
# AVAILABLE_MODELS=[{"id":"gpt-4o","display_name":"GPT-4o","owned_by":"openai"}]
